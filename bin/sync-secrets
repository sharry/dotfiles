#!/usr/bin/env bash
# Syncs build-time secrets from Infisical into the sops-encrypted secrets file.
# Runtime env vars continue to be handled by infisync.
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
SECRETS="$DOTFILES/secrets/secrets.yaml"
CONF="${XDG_CONFIG_HOME:-$HOME/.config}/infisical/infisical.conf"

if [ ! -f "$CONF" ]; then
  CONF="$DOTFILES/programs/infisical/infisical.conf"
fi

require_build_secrets() {
  local json="$1"
  local key
  local -a missing=()
  local -a required=(
    email
    fullname
    whisper_hostname
    ssh_id_ed25519_personal
    ssh_id_ed25519_personal_pub
    ssh_id_ed25519_work
    ssh_id_ed25519_work_pub
    ssh_id_ed25519_secure
    ssh_id_ed25519_secure_pub
  )

  for key in "${required[@]}"; do
    if ! jq -e --arg key "$key" 'any(.[]; (.key | ascii_downcase) == $key)' >/dev/null <<<"$json"; then
      missing+=("$key")
    fi
  done

  if [ ${#missing[@]} -gt 0 ]; then
    printf 'Missing required build secrets in Infisical: %s\n' "${missing[*]}" >&2
    exit 1
  fi
}

if [ -f "$CONF" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONF"
  set +a
fi

json=$(infisical export \
  --silent \
  --format=json \
  --projectId "${INFISICAL_MACHINE_PROJECT_ID:?Set INFISICAL_MACHINE_PROJECT_ID in $CONF}" \
  --env "${INFISICAL_MACHINE_ENV:-macbook}" \
  --path "${INFISICAL_MACHINE_PATH:-/}" \
  ${INFISICAL_MACHINE_DOMAIN:+--domain "$INFISICAL_MACHINE_DOMAIN"} \
  ${INFISICAL_MACHINE_TOKEN:+--token "$INFISICAL_MACHINE_TOKEN"})

require_build_secrets "$json"

# Convert Infisical JSON to a proper YAML object with lowercase keys
mkdir -p "$(dirname "$SECRETS")"
echo "$json" | jq '[.[] | {(.key | ascii_downcase): .value}] | add // {}' | yq -P > "$SECRETS"

# Encrypt in-place — sops matches the file path against .sops.yaml creation_rules
sops encrypt -i "$SECRETS"

echo "Build secrets synced to $SECRETS"
