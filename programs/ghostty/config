title = " "
theme = dark:catppuccin-mocha.conf,light:catppuccin-latte.conf
mouse-hide-while-typing = true
background-blur-radius = 20
background-opacity = 0.85
macos-titlebar-style = transparent
macos-icon = xray

keybind = super+p=new_split:right
keybind = super+d=new_split:down
keybind = super+arrow_up=goto_split:up
keybind = super+arrow_down=goto_split:down
keybind = super+arrow_left=goto_split:left
keybind = super+arrow_right=goto_split:right
keybind = super+]=next_tab
keybind = super+[=previous_tab
keybind = super+f=toggle_quick_terminal

window-save-state = always
window-padding-balance = true
window-padding-x = 0
window-padding-y = 3

quick-terminal-autohide = false
quick-terminal-animation-duration = 0
quick-terminal-space-behavior = remain
