{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"figma": {
			"type": "local",
			"command": ["npx", "-y", "figma-developer-mcp", "--figma-api-key=$FIGMA_API_KEY", "--stdio"]
		}
	},
	"autoupdate": true,
	"permission": {
		"*": "allow",
		"edit": "ask"
	},
	"plugin": [
		"opencode-gemini-auth@latest",
		"opencode-claude-auth@latest"
	],
	"provider": {
		"whisper": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Whisper",
			"options": {
				"baseURL": "http://100.116.167.75:11434/v1"
			},
			"models": {
				"gemma4": {}
			}
		}
	}
}
